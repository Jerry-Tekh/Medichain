PRIVATE_KEY=
TREASURE_ADDRESS=

# Backend runtime
MEDICHAIN_ENV=production
MEDICHAIN_BACKEND_MODE=genlayer
MEDICHAIN_CONTRACT_ADDRESS=0xebb0590f54Aaf1bA1Cfd544325307759c1F79e50
GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com
GENLAYER_NETWORK=testnet-bradbury
GENLAYER_ACCOUNT_NAME=medichain-production
GENLAYER_CLI_COMMAND=genlayer
GENLAYER_CLI_FEES={"distribution":{"leaderTimeunitsAllocation":"1000","validatorTimeunitsAllocation":"1000","rotations":["0"]}}
GENLAYER_KEYSTORE_PASSWORD=
GENLAYER_TIMEOUT_SECONDS=600

# Comma-separated frontend origins allowed to call the API.
ALLOWED_ORIGINS=https://your-frontend-domain.com
# Comma-separated API hostnames, without scheme or path.
ALLOWED_HOSTS=your-api-domain.com

# Wallet signature authentication
MEDICHAIN_WALLET_AUTH_REQUIRED=true
DATABASE_URL=postgresql://user:password@host:5432/medichain
JWT_SECRET=
JWT_ISSUER=medichain-api
JWT_AUDIENCE=medichain-web
MEDICHAIN_AUTH_DOMAIN=your-frontend-domain.com
MEDICHAIN_AUTH_URI=https://your-frontend-domain.com
MEDICHAIN_AUTH_CHAIN_ID=4221
MEDICHAIN_AUTH_CHALLENGE_TTL_SECONDS=300
MEDICHAIN_AUTH_SESSION_TTL_SECONDS=3600
# Comma-separated lowercase or mixed-case wallet addresses.
MEDICHAIN_ADMIN_WALLETS=
MEDICHAIN_REGULATOR_WALLETS=

# Local development mode only.
MEDICHAIN_STATE_PATH=data/medichain_state.json

# Frontend build environment (Vercel/static host).
API_BASE_URL=https://your-api-domain.com
WALLET_CHAIN_ID=4221
WALLET_CHAIN_NAME=GenLayer Bradbury
WALLET_RPC_URL=https://rpc.testnet-chain.genlayer.com
WALLET_EXPLORER_URL=https://explorer.testnet-chain.genlayer.com
